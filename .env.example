# Baseline Environment Variables
# Copy this file to .env and configure secrets as needed.

# Application Keys
# API_KEY=your_key_here

# Worker role boundary
# Set as a Cloudflare Worker secret in production:
# npx wrangler secret put TRIP_ADMIN_TOKEN
# TRIP_ADMIN_TOKEN=change-me

# Frontend API boundary
# In production the app uses same-origin /api/* through the Cloudflare Worker.
# Local Vite dev falls back to the deployed Worker unless this is set.
# VITE_TRIP_API_BASE=https://trip.thomasrynell.workers.dev
